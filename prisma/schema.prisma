generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  MANAGER
  USER
}

enum Recurrence {
  NONE
  SIX_MONTHS
  ONE_YEAR
  TWO_YEARS
}

enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  SCORM_COMPLETED
  EXAM_PASSED
  EXAM_FAILED
  RETAKE_REQUIRED
  COMPLETED
  OVERDUE
}

enum AttemptType {
  SCORM
  EXAM
}

// Assignment'ın hangi tetikleyici tarafından üretildiğini kaydeder. Denetim
// ve raporlama için önemli: otomatik periyodik döngü mü, kullanıcının gönüllü
// tekrarı mı, yoksa yönetici zorunlu kılışı mı?
enum AssignmentTrigger {
  AUTO
  VOLUNTARY
  MANAGER_REQUESTED
}

enum TokenType {
  INVITE
  RESET
}

model PasswordToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  type      TokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

enum ScormVersion {
  SCORM_12
  SCORM_2004
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String
  passwordHash  String?
  failedLoginAttempts Int    @default(0)
  lockedAt      DateTime?
  azureAdOid    String?      @unique
  role          Role         @default(USER)
  departmentId  String?
  department    Department?  @relation(fields: [departmentId], references: [id])
  managerId     String?
  manager       User?        @relation("TeamManager", fields: [managerId], references: [id])
  reports       User[]       @relation("TeamManager")
  isActive      Boolean      @default(true)
  // Kişisel bilgiler (sertifikada görünür). Opsiyonel — eski kayıtlar null kalır.
  birthDate     DateTime?    @db.Date
  birthPlace    String?
  // Tercih edilen arayüz/mail dili. LocaleSwitcher DB'yi günceller;
  // mail gönderirken bu alan okunur. Varsayılan "en" — DEFAULT_LOCALE ile eşleşmeli.
  locale        String       @default("en")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  assignments   Assignment[]
  // Gönüllü tekrar veya yönetici tarafından tetiklenen assignment'lar.
  triggeredAssignments Assignment[] @relation("AssignmentTriggeredBy")
  plansCreated  TrainingPlan[] @relation("PlanCreator")
  certificates  Certificate[]
  auditLogs     AuditLog[]
  jobTitles     UserJobTitle[]
  passwordTokens PasswordToken[]
  revisionsCreated CourseRevision[]
  notifications Notification[]
  ownedCourses  Course[]     @relation("CourseOwner")

  @@index([departmentId])
  @@index([role])
}

model JobTitle {
  id        String                 @id @default(cuid())
  name      String                 @unique
  users     UserJobTitle[]
  plans     TrainingPlanJobTitle[]
  createdAt DateTime               @default(now())
}

model UserJobTitle {
  userId     String
  jobTitleId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobTitle   JobTitle @relation(fields: [jobTitleId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([userId, jobTitleId])
  @@index([jobTitleId])
}

model TrainingPlanJobTitle {
  planId     String
  jobTitleId String
  plan       TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  jobTitle   JobTitle     @relation(fields: [jobTitleId], references: [id], onDelete: Cascade)

  @@id([planId, jobTitleId])
  @@index([jobTitleId])
}

model Department {
  id        String  @id @default(cuid())
  name      String  @unique
  users     User[]
  createdAt DateTime @default(now())
}

model Course {
  id                String        @id @default(cuid())
  title             String
  description       String?
  scormPackagePath  String?
  scormEntryPoint   String?
  scormVersion      ScormVersion  @default(SCORM_12)
  passingScore      Int           @default(70)
  durationMinutes   Int?
  isActive          Boolean       @default(true)
  currentRevision   Int           @default(1)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Bu kurstan sorumlu yönetici. Yeni kurs oluştururken zorunlu; sertifika
  // PDF'inde "Sorumlu" olarak basılır. Yönetici silinemesin / kurs yetim
  // kalmasın diye Restrict — önce Course owner değiştirilmeli.
  ownerManagerId    String?
  ownerManager      User?         @relation("CourseOwner", fields: [ownerManagerId], references: [id], onDelete: Restrict)

  questionBank      QuestionBank?
  exam              Exam?
  plans             TrainingPlan[]
  revisions         CourseRevision[]

  @@index([ownerManagerId])
}

model CourseRevision {
  id               String       @id @default(cuid())
  courseId         String
  course           Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  revisionNumber   Int
  // Snapshot of the course state at the time the revision was created.
  title            String
  description      String?
  scormPackagePath String?
  scormEntryPoint  String?
  scormVersion     ScormVersion
  passingScore     Int
  // Admin-provided note describing what changed in this revision.
  changeNote       String?
  createdById      String
  createdBy        User         @relation(fields: [createdById], references: [id])
  createdAt        DateTime     @default(now())

  @@unique([courseId, revisionNumber])
  @@index([courseId])
}

model QuestionBank {
  id        String     @id @default(cuid())
  courseId  String     @unique
  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions Question[]
  createdAt DateTime   @default(now())
}

model Question {
  id        String         @id @default(cuid())
  bankId    String
  bank      QuestionBank   @relation(fields: [bankId], references: [id], onDelete: Cascade)
  text      String
  points    Int            @default(1)
  options   AnswerOption[]
}

model AnswerOption {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false)
}

model Exam {
  id            String  @id @default(cuid())
  courseId      String  @unique
  course        Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questionCount Int     @default(10)
  passingScore  Int     @default(70)
  timeLimitMin  Int?
  shuffle       Boolean @default(true)
}

model TrainingPlan {
  id          String                 @id @default(cuid())
  courseId    String
  course      Course                 @relation(fields: [courseId], references: [id])
  recurrence  Recurrence             @default(NONE)
  startDate   DateTime
  dueInDays   Int                    @default(30)
  createdById String
  createdBy   User                   @relation("PlanCreator", fields: [createdById], references: [id])
  assignments Assignment[]
  jobTitles   TrainingPlanJobTitle[]
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())

  @@index([courseId])
}

model Assignment {
  id             String           @id @default(cuid())
  planId         String
  plan           TrainingPlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycleNumber    Int              @default(1)
  status         AssignmentStatus @default(PENDING)
  dueDate        DateTime
  startedAt      DateTime?
  completedAt    DateTime?
  // Revision of the course this assignment was issued against. Lets us show
  // users which version they completed and detect when a newer revision exists.
  revisionNumber Int?
  createdAt      DateTime         @default(now())

  // Tetikleyici. AUTO: cron (recurrence) — varsayılan (eski kayıtlar).
  // VOLUNTARY: kullanıcı kendi başlattı. MANAGER_REQUESTED: yönetici/admin zorunlu kıldı.
  triggeredBy    AssignmentTrigger @default(AUTO)
  // Manuel tetiklendiyse (VOLUNTARY/MANAGER_REQUESTED) kimin tetiklediği.
  triggeredById  String?
  triggeredBy_User User?            @relation("AssignmentTriggeredBy", fields: [triggeredById], references: [id], onDelete: SetNull)
  // Yönetici zorunlu kıldıysa sebep (audit + kullanıcıya gösterim için).
  triggerReason  String?

  attempts     Attempt[]
  examAttempts ExamAttempt[]
  examSessions ExamSession[]
  certificate  Certificate?

  @@unique([planId, userId, cycleNumber])
  @@index([userId, status])
  @@index([dueDate])
}

model Attempt {
  id           String      @id @default(cuid())
  assignmentId String
  assignment   Assignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  type         AttemptType
  score        Float?
  passed       Boolean?
  cmiData      Json?
  startedAt    DateTime    @default(now())
  finishedAt   DateTime?
}

model ExamAttempt {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  attemptNo    Int
  score        Float
  passed       Boolean
  answers      Json
  createdAt    DateTime   @default(now())

  @@unique([assignmentId, attemptNo])
}

// Bir kullanıcının bir atamadaki bir deneme için server tarafında snapshot'lanan
// soru kümesi. Sınav başlangıcında (GET /exam/[assignmentId]) oluşur; submit
// zamanında sunucu bu snapshot'a göre puanlar — cevap gönderilmemiş sorular
// yanlış sayılır. Böylece istemci "sadece bildiklerimi gönderdim → %100" hilesi
// yapamaz. submittedAt NOT NULL olduğunda tekrar kullanılamaz; yeni attemptNo
// için yeni bir satır oluşturulur.
model ExamSession {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  attemptNo    Int
  questionIds  String[]
  createdAt    DateTime   @default(now())
  submittedAt  DateTime?

  @@unique([assignmentId, attemptNo])
  @@index([assignmentId])
}

model Certificate {
  id           String     @id @default(cuid())
  assignmentId String     @unique
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  pdfPath      String
  issuedAt     DateTime   @default(now())
  serialNo     String     @unique
  // Veriliş anındaki şablon ayarlarının kopyası. Şablon sonradan değişse
  // bile sertifika PDF'i orijinal haliyle yeniden üretilir — uyum/yasal
  // bir gereklilik, "bu tarihte sertifika şu şekildeydi" kanıtı.
  templateSnapshot Json?
}

// Kurum genelinde tek satırlı ayar tablosu (id="singleton"). Şu an yalnızca
// sertifika şablonu tutuluyor; ileride başka kurumsal görünüm ayarları da
// buraya eklenebilir. Tek satır garantisi uygulama kodunda (upsert) sağlanır.
model OrganizationSettings {
  id                         String   @id @default("singleton")
  certAccentColor            String   @default("#e30613")
  certTitleAchievement       String   @default("BAŞARI SERTİFİKASI")
  certTitleParticipation     String   @default("KATILIM SERTİFİKASI")
  certSubtitleAchievement    String   @default("CERTIFICATE OF ACHIEVEMENT")
  certSubtitleParticipation  String   @default("CERTIFICATE OF PARTICIPATION")
  certBodyAchievement        String   @default("eğitimini başarıyla tamamladığını belgelemek üzere düzenlenmiştir.")
  certBodyParticipation      String   @default("eğitimine katıldığını belgelemek üzere düzenlenmiştir.")
  certFooterLine             String   @default("Bon Air Havacılık Sanayi ve Ticaret A.Ş. · BonAcademy")
  // Görünürlük bayrakları — hangi opsiyonel alanların sertifikada gösterileceği.
  certShowBirthDate          Boolean  @default(true)
  certShowBirthPlace         Boolean  @default(true)
  certShowOwnerManager       Boolean  @default(true)
  certShowQr                 Boolean  @default(true)
  updatedAt                  DateTime @updatedAt
  updatedById                String?
}

model AppOption {
  id        String   @id @default(cuid())
  category  String
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([category, label])
  @@index([category])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Dedup anahtarı (örn. "assignment:<id>:new" / "...:reminder:7" / "...:overdue").
  type      String
  channel   String
  sentAt    DateTime @default(now())

  @@unique([userId, type])
  @@index([userId])
  @@index([sentAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  // Aktör silinse bile log kalır (yasal kanıt). FK SetNull; denetim
  // görüntüleyicide "kullanıcı silinmiş" olarak gösterilir.
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
  @@index([actorId])
  @@index([action])
}
