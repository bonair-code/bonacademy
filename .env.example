# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bonacademy?schema=public"

# NextAuth
AUTH_SECRET="change-me-use-openssl-rand-hex-32"
NEXTAUTH_URL="http://localhost:3000"

# Azure AD / Microsoft 365 SSO
AUTH_AZURE_AD_CLIENT_ID=""
AUTH_AZURE_AD_CLIENT_SECRET=""
AUTH_AZURE_AD_TENANT_ID=""

# Azure Blob Storage (SCORM packages)
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER="scorm-packages"

# Email (SMTP or Azure Communication Services)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="BonAcademy <noreply@bonair.com.tr>"

# App
APP_URL="http://localhost:3000"
APP_LOCALE="tr"

# Google reCAPTCHA v3 (login bot koruması)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# Cron endpoint secret. Üret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Vercel Cron'un Authorization: Bearer <CRON_SECRET> header'ı ile bu değer eşleşmek zorunda.
CRON_SECRET=""
