# =================================================================
# BonAcademy — Environment Variables
# Production'da Vercel Settings > Environment Variables üzerinden
# eklenir. Lokal için .env.local dosyasına kopyala.
# =================================================================

# --- Database (zorunlu) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bonacademy?schema=public"

# --- NextAuth / Auth.js (zorunlu) ---
# AUTH_SECRET üret: openssl rand -base64 32
AUTH_SECRET="change-me-use-openssl-rand-base64-32"
# Production'da custom domain bağlanınca güncelle.
AUTH_URL="http://localhost:3000"

# --- Azure AD / Microsoft 365 SSO (opsiyonel — yoksa M365 butonu gizlenir) ---
AUTH_AZURE_AD_CLIENT_ID=""
AUTH_AZURE_AD_CLIENT_SECRET=""
AUTH_AZURE_AD_TENANT_ID=""

# --- SCORM Storage ---
# Vercel'de: Storage > Create Blob Store → token otomatik gelir.
BLOB_READ_WRITE_TOKEN=""
# Eski Azure Blob (Vercel Blob varsa kullanılmaz):
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER="scorm-packages"

# --- E-posta (SMTP — zorunlu) ---
# M365 için: smtp.office365.com / 587 / STARTTLS / app password
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
SMTP_USER="noreply@bonair.com.tr"
SMTP_PASS=""
SMTP_FROM="BonAcademy <noreply@bonair.com.tr>"

# --- Google reCAPTCHA v3 (zorunlu — login bot koruması) ---
# https://www.google.com/recaptcha/admin/create → v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# --- Cron secret (zorunlu) ---
# Üret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Vercel Cron Authorization: Bearer <CRON_SECRET> ile bu değeri yollar.
CRON_SECRET=""

# --- İlk Kurulum Sihirbazı (opsiyonel ama ÖNERİLİR) ---
# /setup sayfasını koruyan rastgele token. DB'de hiç ADMIN yokken setup
# sayfasından ilk yöneticiyi oluştururken sorulur. Üretim ortamında mutlaka
# tanımla — aksi hâlde public erişim riski olur.
SETUP_TOKEN=""

# --- Seed (opsiyonel — npm run db:seed için) ---
SEED_ADMIN_EMAIL="admin@bonair.com.tr"
SEED_ADMIN_NAME="Sistem Yöneticisi"
SEED_ADMIN_PASSWORD=""
